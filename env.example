# ═══════════════════════════════════════════════════════
# AI Business Development System — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# PHASE 1 — Required from Day 1
# ─────────────────────────────────────────────

# Anthropic API — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — https://supabase.com (free tier is fine)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # use service_role key, not anon

# n8n self-hosted
N8N_HOST=YOUR_VPS_IP_OR_DOMAIN
N8N_PROTOCOL=http
N8N_USER=admin
N8N_PASSWORD=choose_a_strong_password
N8N_DB_PASSWORD=choose_a_postgres_password

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
NOTIFICATION_EMAIL=you@yourdomain.com

# ─────────────────────────────────────────────
# PHASE 2 — Market Intelligence Agent
# ─────────────────────────────────────────────

# NOAA Climate Data Online — https://www.ncdc.noaa.gov/cdo-web/token (free)
NOAA_API_KEY=...

# FRED Economic Data — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=...

# SerpAPI (Google Trends proxy) — https://serpapi.com (100 free searches/mo)
SERPAPI_KEY=...

# ─────────────────────────────────────────────
# PHASE 3 — Lead Targeting Agent
# ─────────────────────────────────────────────

# Google Maps API — https://console.cloud.google.com
# Enable: Places API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=...

# Apollo.io — https://app.apollo.io/#/settings/integrations/api
# Plan: Basic $49/mo = 300 email credits + 2,400 mobile credits/mo
APOLLO_API_KEY=...

# RapidAPI (Indeed job postings) — https://rapidapi.com/letscrape-6bRBa3QguO5/api/indeed-scraper
RAPIDAPI_KEY=...

# ─────────────────────────────────────────────
# PHASE 4 — Outreach Agent (Email)
# ─────────────────────────────────────────────

# Instantly.ai — https://app.instantly.ai/app/settings/integrations
# Plan: Growth $37/mo = unlimited email accounts + sequences
INSTANTLY_API_KEY=...

# Sending domain 1 (buy a cheap domain, e.g. yourbrand-solutions.com)
SENDING_DOMAIN_1=yourbrand-solutions.com
SENDING_EMAIL_1=mike@yourbrand-solutions.com

# Sending domain 2
SENDING_DOMAIN_2=tryyourbrand.com
SENDING_EMAIL_2=sarah@tryyourbrand.com

# ─────────────────────────────────────────────
# PHASE 5 — Outreach Agent (LinkedIn)
# ─────────────────────────────────────────────

# Waalaxy — https://app.waalaxy.com (plan ~$40/mo)
WAALAXY_API_KEY=...

# ─────────────────────────────────────────────
# PHASE 6 — Nurture + Close Agent
# ─────────────────────────────────────────────

# GoHighLevel — https://app.gohighlevel.com
# Plan: $97/mo — CRM + sequences + SMS + landing pages
GHL_API_KEY=...
GHL_LOCATION_ID=...  # find in GHL Settings > Business Info

# Twilio (SMS) — https://console.twilio.com
# $10 credit lasts months at $0.0075/SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Calendly (webhook for booking events) — https://calendly.com/integrations/api
CALENDLY_API_KEY=...
CALENDLY_WEBHOOK_SECRET=...  # for validating incoming webhooks

# PandaDoc (proposals + contracts) — https://app.pandadoc.com/api-dashboard
# Plan: Starter $35/mo
PANDADOC_API_KEY=...
PANDADOC_PROPOSAL_TEMPLATE_ID=...

# Fathom / Fireflies (call recording + AI notes — optional)
FATHOM_API_KEY=...

# ─────────────────────────────────────────────
# COST ALERT THRESHOLDS
# ─────────────────────────────────────────────

COST_ALERT_DAILY_USD=5.00
COST_ALERT_WEEKLY_USD=25.00
COST_PER_LEAD_ALERT_USD=0.10

# ─────────────────────────────────────────────
# SYSTEM CONFIG
# ─────────────────────────────────────────────

# Current build phase (1–7) — used by validation gate runner
CURRENT_PHASE=1

# Max leads to enrich per run (prevents runaway Apollo spend)
MAX_LEADS_PER_RUN=50

# Max hot leads to enroll in outreach per week
MAX_OUTREACH_PER_WEEK=100

# Timezone for all scheduling
SYSTEM_TIMEZONE=America/Chicago
